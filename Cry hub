-- Save config
local function saveConfig()
    if not writefile then
        warn("[CryHub] writefile not supported")
        return false
    end
    local ok, err = pcall(function()
        if makefolder and isfolder then
            if not isfolder("CryHub") then
                makefolder("CryHub")
            end
        end
        writefile("CryHub/Config.json", HttpService:JSONEncode(config))
    end)
    if not ok then
        warn("[CryHub] Config save error: " .. tostring(err))
        return false
    end
    return ok
end

-- Load config
local function loadConfig()
    if not readfile or not isfile then return false end
    local ok = pcall(function()
        if isfile("CryHub/Config.json") then
            local decoded = HttpService:JSONDecode(readfile("CryHub/Config.json"))
            if decoded then
                for k, v in pairs(decoded) do
                    if config[k] ~= nil then
                        config[k] = v
                    end
                end
            end
        end
    end)
    return ok
end

