local autoStealConnections = {}

local function setAutoSteal(enabled)
    config.autoSteal = enabled
    for _, c in ipairs(autoStealConnections) do
        pcall(function() c:Disconnect() end)
    end
    autoStealConnections = {}

    if enabled then
        -- Attempt to find and interact with steal remotes
        local function trySteal(player)
            if not player or player == LocalPlayer then return end
            task.spawn(function()
                pcall(function()
                    -- Generic steal attempt via RemoteEvents
                    local remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes") or game:GetService("ReplicatedStorage"):FindFirstChild("RE")
                    if remotes then
                        local stealRemote = remotes:FindFirstChild("Steal") or remotes:FindFirstChild("AutoSteal") or remotes:FindFirstChild("UseItem")
                        if stealRemote and stealRemote:IsA("RemoteEvent") then
                            stealRemote:FireServer(player)
                        end
                    end
                end)
            end)
        end

        for _, player in ipairs(Players:GetPlayers()) do
            trySteal(player)
        end

        local conn = Players.PlayerAdded:Connect(function(player)
            if config.autoSteal then
                task.wait(1)
                trySteal(player)
            end
        end)
        table.insert(autoStealConnections, conn)
    end
end

-- ==============================
-- AIMBOT
-- ==============================

local aimbotConn
local aimbotActive = false

local function setAimbot(enabled)
    config.aimbot = enabled
    aimbotActive = enabled
    if enabled then
        aimbotConn = RunService.Heartbeat:Connect(function()
            if not aimbotActive then return end

            local camera = Workspace.CurrentCamera
            local nearest = nil
            local minDist = math.huge

            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local dist = (hrp.Position - camera.CFrame.Position).Magnitude
                        if dist < minDist then
                            minDist = dist
                            nearest = hrp
                        end
                    end
                end
            end

            if nearest then
                local targetCF = CFrame.new(camera.CFrame.Position, nearest.Position)
                camera.CFrame = camera.CFrame:Lerp(targetCF, 0.08)
            end
        end)
    else
        if aimbotConn then
            aimbotConn:Disconnect()
            aimbotConn = nil
        end
    end
end

