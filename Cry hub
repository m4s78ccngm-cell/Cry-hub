local antiDieConnections = {}

local function applyAntiDie(character)
    if not character then return end

    -- Clear old connections
    for _, c in ipairs(antiDieConnections) do
        pcall(function() c:Disconnect() end)
    end
    antiDieConnections = {}

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    -- Prevent health from reaching 0
    pcall(function()
        humanoid.BreakJointsOnDeath = false
    end)

    -- Force field to prevent death
    if not character:FindFirstChildOfClass("ForceField") then
        local ff = Instance.new("ForceField")
        ff.Visible = false
        ff.Parent = character
    end

    -- Monitor health
    local hpConn = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
        if config.antiDie and humanoid.Health <= 0 then
            pcall(function() humanoid.Health = humanoid.MaxHealth end)
        end
    end)
    table.insert(antiDieConnections, hpConn)

    -- Monitor state
    local stateConn = humanoid.StateChanged:Connect(function(_, new)
        if config.antiDie and new == Enum.HumanoidStateType.Dead then
            pcall(function()
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Dead, false)
            end)
        end
    end)
    table.insert(antiDieConnections, stateConn)
end

local function setAntiDie(enabled)
    config.antiDie = enabled
    if enabled then
        applyAntiDie(getCharacter())
    else
        for _, c in ipairs(antiDieConnections) do
            pcall(function() c:Disconnect() end)
        end
        antiDieConnections = {}
    end
end

LocalPlayer.CharacterAdded:Connect(function(char)
    if config.antiDie then
