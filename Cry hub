local originalGraphics = {}

local function startReduceGraphics()
    originalGraphics = {}
    local lighting = game:GetService("Lighting")

    -- Store originals
    originalGraphics.GlobalShadows = lighting.GlobalShadows
    originalGraphics.FogEnd = lighting.FogEnd
    originalGraphics.Brightness = lighting.Brightness

    for _, effect in ipairs(lighting:GetChildren()) do
        if effect:IsA("PostEffect") then
            originalGraphics[effect] = effect.Enabled
            effect.Enabled = false
        end
    end

    lighting.GlobalShadows = false
    lighting.FogEnd = 100000
    lighting.Brightness = 1

    settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
end

local function stopReduceGraphics()
    local lighting = game:GetService("Lighting")
    if originalGraphics.GlobalShadows ~= nil then
        lighting.GlobalShadows = originalGraphics.GlobalShadows
    end
    if originalGraphics.FogEnd ~= nil then
        lighting.FogEnd = originalGraphics.FogEnd
    end
    if originalGraphics.Brightness ~= nil then
        lighting.Brightness = originalGraphics.Brightness
    end

    for effect, val in pairs(originalGraphics) do
        if typeof(effect) == "Instance" then
            effect.Enabled = val
        end
    end

    settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
end

local function setReduceGraphics(enabled)
    config.reduceGraphics = enabled
    if enabled then
        startReduceGraphics()
    else
        stopReduceGraphics()
    end
end

-- ==============================
-- SERVER HOPPER
-- ==============================

local hopperActive = false
local hopperTask
local hopperErrorCount = 0
local hopperMaxErrors = 3
local placeId = game.PlaceId

local function doHop(statusLabel)
    local function attemptTeleport()
        game:GetService("TeleportService"):TeleportToRandomServer(placeId)
    end

    local ok, err = pcall(attemptTeleport)
    if not ok then
        warn("[CryHub Hopper] TeleportToRandomServer failed: " .. tostring(err))
        local lower = tostring(err):lower()

        if lower:find("restricted") or lower:find("access denied") or lower:find("not authorized") then
            if statusLabel then
                statusLabel.Text = "Status: Server restricted, skipping..."
                statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
            end
            task.wait(2)
            hopperErrorCount = hopperErrorCount + 1
        else
            task.wait(1)
            local ok2, err2 = pcall(function()
                game:GetService("TeleportService"):Teleport(placeId)
            end)
            if not ok2 then
                warn("[CryHub Hopper] Fallback teleport failed: " .. tostring(err2))
                hopperErrorCount = hopperErrorCount + 1
                task.wait(3)
            end
        end
    end
end

local function setHopper(enabled, statusLabel)
    config.hopperEnabled = enabled
    if enabled then
        hopperActive = true
        hopperErrorCount = 0
        hopperTask = task.spawn(function()
            while hopperActive do
                -- Wait a bit before teleporting
                local waitTime = math.random(2, 6) / 10
                task.wait(waitTime)
                if not hopperActive then break end

                if hopperErrorCount >= hopperMaxErrors then
                    hopperErrorCount = 0
                    task.wait(5)
                end
                if statusLabel then
                    statusLabel.Text = "Status: Waiting after teleport errors..."
                    statusLabel.TextColor3 = Color3.fromRGB(255, 200, 50)
                end
                doHop(statusLabel)
            end
        end)
    else
        hopperActive = false
    end
end

